{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!node_modules", "!.pnpm-store"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "plugins": ["./rules/react-google-translate.grit"],
  "linter": {
    "enabled": true
  }
}
