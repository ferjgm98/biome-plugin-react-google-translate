{
  "name": "biome-plugin-react-google-translate",
  "version": "0.1.3",
  "description": "Biome GritQL lint rules for React text-node patterns that can break under Google Translate DOM mutation.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ferjgm98/biome-plugin-react-google-translate.git"
  },
  "bugs": {
    "url": "https://github.com/ferjgm98/biome-plugin-react-google-translate/issues"
  },
  "homepage": "https://github.com/ferjgm98/biome-plugin-react-google-translate#readme",
  "keywords": [
    "biome",
    "biome-plugin",
    "gritql",
    "react",
    "google-translate",
    "lint"
  ],
  "files": [
    "bin",
    "rules",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "exports": {
    "./react-google-translate.grit": "./rules/react-google-translate.grit",
    "./rules/react-google-translate.grit": "./rules/react-google-translate.grit"
  },
  "bin": {
    "biome-plugin-react-google-translate": "./bin/cli.mjs",
    "react-google-translate-fix": "./bin/cli.mjs"
  },
  "scripts": {
    "lint": "biome check --files-ignore-unknown=true package.json biome.json bin scripts rules",
    "fix:fixtures": "node bin/cli.mjs fix fixtures/invalid --write",
    "verify": "node scripts/verify.mjs",
    "fixtures:valid": "biome lint fixtures/valid",
    "fixtures:invalid": "biome lint fixtures/invalid"
  },
  "dependencies": {
    "@babel/generator": "^8.0.0",
    "@babel/parser": "^8.0.0"
  },
  "peerDependencies": {
    "@biomejs/biome": ">=2.5.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2"
  },
  "packageManager": "pnpm@11.7.0"
}
